---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const allTags = [...new Set(posts.flatMap((post) => post.data.tags || []))].sort();
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 100%;
				max-width: 1200px;
				margin: 0 auto;
				padding: 2rem;
				display: grid;
				grid-template-columns: 250px 1fr;
				gap: 3rem;
			}
			aside {
				padding-top: 2rem;
			}
			.filter-section {
				position: sticky;
				top: 2rem;
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
			}
			.tag-checkbox-container {
				display: block;
				position: relative;
				padding-left: 35px;
				margin-bottom: 12px;
				cursor: pointer;
				font-size: 1rem;
				user-select: none;
			}
			.tag-checkbox-container input {
				position: absolute;
				opacity: 0;
				cursor: pointer;
				height: 0;
				width: 0;
			}
			.checkmark {
				position: absolute;
				top: 0;
				left: 0;
				height: 25px;
				width: 25px;
				background-color: #eee;
				border-radius: 4px;
			}
			.tag-checkbox-container:hover input ~ .checkmark {
				background-color: #ccc;
			}
			.tag-checkbox-container input:checked ~ .checkmark {
				background-color: var(--accent);
			}
			.checkmark:after {
				content: "";
				position: absolute;
				display: none;
			}
			.tag-checkbox-container input:checked ~ .checkmark:after {
				display: block;
			}
			.tag-checkbox-container .checkmark:after {
				left: 9px;
				top: 5px;
				width: 5px;
				height: 10px;
				border: solid white;
				border-width: 0 3px 3px 0;
				transform: rotate(45deg);
			}
			hr {
				border: 0;
				border-top: 1px solid #eee;
				margin: 0.5rem 0;
			}
			section {
				width: 100%;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
				width: 100%;
				height: auto;
				aspect-ratio: 16/9;
				object-fit: cover;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.2;
				font-size: 1.25rem;
			}
			.date {
				margin: 0.5rem 0 0;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			@media (max-width: 900px) {
				main {
					grid-template-columns: 1fr;
				}
				aside {
					order: -1;
					padding-top: 0;
				}
				.tag-list {
					display: flex;
					flex-wrap: wrap;
					gap: 0.5rem;
					position: static;
				}
				ul li {
					width: 100%;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<aside>
				<h3>Filter</h3>
				<div class="filter-section">
					<label class="tag-checkbox-container">
						<input type="checkbox" id="check-all" checked />
						<span class="checkmark"></span>
						Alle Beiträge
					</label>
					<hr />
					{allTags.map((tag) => (
						<label class="tag-checkbox-container">
							<input type="checkbox" class="tag-checkbox" value={tag} />
							<span class="checkmark"></span>
							{tag}
						</label>
					))}
				</div>
			</aside>
			<section>
				<ul id="post-list">
					{
						posts.map((post) => (
							<li class="post-item" data-tags={JSON.stringify(post.data.tags || [])}>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>

		<script>
			const checkAll = document.getElementById('check-all') as HTMLInputElement;
			const tagCheckboxes = document.querySelectorAll('.tag-checkbox') as NodeListOf<HTMLInputElement>;
			const posts = document.querySelectorAll('.post-item') as NodeListOf<HTMLElement>;

			function updateFilter() {
				const selectedTags = Array.from(tagCheckboxes)
					.filter(cb => cb.checked)
					.map(cb => cb.value);

				const showAll = checkAll.checked;

				posts.forEach(post => {
					const postTags = JSON.parse(post.getAttribute('data-tags') || '[]');
					
					if (showAll) {
						post.style.display = 'block';
					} else if (selectedTags.length === 0) {
						post.style.display = 'none'; // Oder 'block' wenn nichts gewählt ist? 'none' ist konsequenter.
					} else {
						const hasMatch = selectedTags.some(tag => postTags.includes(tag));
						post.style.display = hasMatch ? 'block' : 'none';
					}
				});
			}

			checkAll?.addEventListener('change', () => {
				if (checkAll.checked) {
					tagCheckboxes.forEach(cb => cb.checked = false);
				}
				updateFilter();
			});

			tagCheckboxes.forEach(cb => {
				cb.addEventListener('change', () => {
					if (cb.checked) {
						checkAll.checked = false;
					}
					updateFilter();
				});
			});
		</script>
		<Footer />
	</body>
</html>
