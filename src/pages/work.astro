---
import Base from "@/layouts/Base.astro";
import { getCollection } from "astro:content";
import { render } from "astro:content";

const collection = await getCollection("work");

// Sort timeline oldest to newest or newest to oldest. Oldest to newest fits "Mein Weg" chronologically.
collection.sort((a, b) => new Date(a.data.dateStart).getTime() - new Date(b.data.dateStart).getTime());

const work = await Promise.all(
  collection.map(async (item) => {
    const { Content } = await render(item);
    return { ...item, Content };
  })
);

function formatWorkDate(input: Date | string) {
  if (typeof input === "string") return input;
  const month = input.toLocaleDateString("de-DE", {
    month: "short",
  });
  const year = new Date(input).getFullYear();
  return `${month} ${year}`;
}
---

<Base title="Mein Weg" description="Meilensteine — wie aus Neugier eine Leidenschaft wurde.">
  <section class="section bg-light/30">
    <div class="container max-w-4xl">
      <!-- Profile Header -->
      <div class="bg-white p-8 rounded-2xl border border-border shadow-sm mb-12 flex flex-col md:flex-row items-center md:items-start gap-8">
        <img 
          src="/avatar.webp" 
          alt="Alexander Graf" 
          class="w-32 h-32 rounded-full object-cover object-top border-4 border-light shadow-md flex-shrink-0"
        />
        <div class="text-center md:text-left">
          <h1 class="h2 mb-2 font-semibold">Alexander Graf</h1>
          <p class="text-primary font-medium text-lg mb-2">Systemarchitekt · Technik-Enthusiast · INTJ</p>
          <p class="text-text/60 text-sm mb-4">Lauf a.d. Pegnitz, Deutschland</p>
          <p class="text-text leading-relaxed text-base max-w-xl">
            Meilensteine — wie aus Neugier eine Leidenschaft wurde. Hier dokumentiere ich meinen technischen Werdegang, vom ersten DOS-PC bis hin zu modernen Cloud- und Docker-Infrastrukturen.
          </p>
        </div>
      </div>

      <!-- Timeline Title -->
      <div class="text-center mb-16">
        <h2 class="h3 font-semibold mb-3">Werdegang & Meilensteine</h2>
        <div class="h-1 w-20 bg-primary mx-auto rounded-full"></div>
      </div>

      <!-- Timeline Items -->
      <div class="relative border-l border-border ml-4 md:ml-6 space-y-12">
        {
          work.map((entry) => (
            <div class="relative pl-8 md:pl-10">
              <!-- Timeline Dot -->
              <div class="absolute -left-[9px] top-1.5 w-4 h-4 rounded-full bg-primary border-4 border-white shadow-sm ring-2 ring-primary/20"></div>
              
              <!-- Timeline Content Card -->
              <div class="bg-white p-6 md:p-8 rounded-2xl border border-border shadow-sm hover:shadow-md transition-shadow duration-200">
                <span class="inline-block px-3 py-1 mb-4 text-xs font-semibold text-primary bg-primary/10 rounded-full">
                  {formatWorkDate(entry.data.dateStart)} – {formatWorkDate(entry.data.dateEnd)}
                </span>
                
                <h3 class="h4 font-semibold text-text-dark mb-1">
                  {entry.data.company}
                </h3>
                
                <p class="text-text/70 text-sm font-medium mb-6">
                  {entry.data.role}
                </p>
                
                <article class="prose max-w-none text-text text-base leading-relaxed">
                  <entry.Content />
                </article>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Base>
