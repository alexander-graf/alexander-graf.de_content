---
import Base from "@/layouts/Base.astro";
import { markdownify } from "@/lib/utils/textConverter";
import type { CollectionEntry } from "astro:content";
import { getEntry } from "astro:content";

const entry = (await getEntry(
  "contact",
  "-index"
)) as CollectionEntry<"contact">;
const { title, description, info } = entry.data;
---

<Base title={title} description={description}>
  <section class="section">
    <div class="container">
      <h1 class="text-center font-semibold mb-12" set:html={markdownify(title)} />
      <div class="section row pb-0 justify-center">
        <!-- Form Section -->
        <div class="col-12 md:col-6 lg:col-7 mb-8 md:mb-0">
          <div class="bg-white p-6 md:p-8 rounded-2xl border border-border shadow-sm">
            <!-- Form Tabs -->
            <div class="flex border-b border-border mb-6">
              <button
                id="tab-btn-mautic"
                class="pb-2 px-4 font-semibold text-sm border-b-2 border-primary text-primary transition-all focus:outline-none cursor-pointer"
                type="button"
              >
                Mautic Formular
              </button>
              <button
                id="tab-btn-ratatosk"
                class="pb-2 px-4 font-semibold text-sm border-b-2 border-transparent text-text/60 hover:text-text transition-all focus:outline-none cursor-pointer"
                type="button"
              >
                Ratatosk Formular (Beta)
              </button>
              <button
                id="tab-btn-newsletter"
                class="pb-2 px-4 font-semibold text-sm border-b-2 border-transparent text-text/60 hover:text-text transition-all focus:outline-none cursor-pointer"
                type="button"
              >
                Newsletter
              </button>
            </div>

            <!-- Tab Content: Mautic -->
            <div id="tab-content-mautic" style="display: block;">
              <div class="mautic-form-wrapper">
                <script
                  is:inline
                  type="text/javascript"
                  src="https://mautic.alexandergraf.de/form/generate.js?id=2"
                ></script>
                <noscript>
                  <a href="https://mautic.alexandergraf.de/form/2" class="btn btn-primary">Zum Kontaktformular</a>
                </noscript>

                <script is:inline>
                  (function() {
                    var tokenAdded = false;
                    function addToken() {
                      if (tokenAdded) return;
                      var form = document.getElementById('mauticform_kontaktformularalexandergrafde');
                      if (form) {
                        var action = form.getAttribute('action');
                        if (action && action.indexOf('token=') === -1) {
                          var separator = action.indexOf('?') !== -1 ? '&' : '?';
                          form.setAttribute('action', action + separator + 'token=alex-secure-token-9988');
                          tokenAdded = true;
                          cleanup();
                        }
                      }
                    }
                    function cleanup() {
                      window.removeEventListener('mousemove', addToken);
                      window.removeEventListener('keydown', addToken);
                      window.removeEventListener('scroll', addToken);
                      window.removeEventListener('touchstart', addToken);
                    }
                    window.addEventListener('mousemove', addToken);
                    window.addEventListener('keydown', addToken);
                    window.addEventListener('scroll', addToken);
                    window.addEventListener('touchstart', addToken);
                  })();
                </script>
              </div>
            </div>

            <!-- Tab Content: Ratatosk (Kontakt) -->
            <div id="tab-content-ratatosk" style="display: none;">
              <div class="ratatosk-form-wrapper flex justify-center">
                <iframe
                  src="https://ratatosk.alexandergraf.de/f/21f69879-51c9-4a1f-b841-b252929e6ed3"
                  style="width:100%;max-width:460px;height:520px;border:0"
                  loading="lazy"
                ></iframe>
              </div>
            </div>

            <!-- Tab Content: Newsletter -->
            <div id="tab-content-newsletter" style="display: none;">
              <div class="ratatosk-form-wrapper flex justify-center">
                <iframe
                  src="https://ratatosk.alexandergraf.de/f/8040a9f7-ed7e-4ed0-83d1-22efed2cac34"
                  style="width:100%;max-width:460px;height:480px;border:0"
                  loading="lazy"
                ></iframe>
              </div>
            </div>
          </div>

          <!-- Tabs Script -->
          <script is:inline>
            (function() {
              function initTabs() {
                const tabs = [
                  { btnId: 'tab-btn-mautic', contentId: 'tab-content-mautic' },
                  { btnId: 'tab-btn-ratatosk', contentId: 'tab-content-ratatosk' },
                  { btnId: 'tab-btn-newsletter', contentId: 'tab-content-newsletter' }
                ];

                const resolvedTabs = tabs.map(t => ({
                  btn: document.getElementById(t.btnId),
                  content: document.getElementById(t.contentId)
                })).filter(t => t.btn && t.content);

                resolvedTabs.forEach(activeTab => {
                  activeTab.btn.addEventListener('click', () => {
                    resolvedTabs.forEach(t => {
                      if (t === activeTab) {
                        t.btn.classList.add('border-primary', 'text-primary');
                        t.btn.classList.remove('border-transparent', 'text-text/60');
                        t.content.style.display = 'block';
                      } else {
                        t.btn.classList.remove('border-primary', 'text-primary');
                        t.btn.classList.add('border-transparent', 'text-text/60');
                        t.content.style.display = 'none';
                      }
                    });
                  });
                });
              }

              // Initialisieren
              initTabs();
              // Falls Astro View Transitions verwendet werden, lauschen wir auf Seitennavigation
              document.addEventListener('astro:page-load', initTabs);
            })();
          </script>
        </div>
        
        <!-- Info Section -->
        <div class="content col-12 md:col-6 lg:col-5">
          <div class="bg-light/50 p-6 md:p-8 rounded-2xl border border-border">
            <h4 class="font-semibold mb-4" set:html={markdownify(info?.title)} />
            <p class="text-text/80 mb-6" set:html={markdownify(info?.description)} />
            <ul class="contact-list list-none pl-0 space-y-4">
              {
                info?.contacts?.map((contact) => (
                  <li class="flex items-start">
                    <span
                      class="text-text-dark font-medium prose"
                      set:html={markdownify(contact)}
                    />
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<style is:global>
  /* Mautic contact form styling integrated with Bigspring Theme */
  .mauticform_wrapper {
    max-width: 100% !important;
    margin: 0 !important;
    font-family: inherit !important;
  }
  .mauticform-name { display: none; }
  .mauticform-input,
  .mauticform-textarea,
  .mauticform-selectbox {
    background: #fff !important;
    border: 1px solid #e9e9e9 !important;
    border-radius: 0.75rem !important; /* soft rounded edges */
    padding: 0.75rem 1rem !important;
    color: #222 !important;
    font-size: 0.95rem !important;
    font-family: inherit !important;
    width: 100% !important;
    box-sizing: border-box !important;
    transition: all 0.2s ease-in-out !important;
  }
  .mauticform-input:focus,
  .mauticform-textarea:focus {
    outline: none !important;
    border-color: #0aa8a7 !important; /* primary color */
    box-shadow: 0 0 0 3px rgba(10, 168, 167, 0.15) !important;
  }
  .mauticform-label {
    font-size: 0.85rem !important;
    font-weight: 600 !important;
    color: #222 !important;
    margin-bottom: 0.5rem !important;
    display: block !important;
  }
  .mauticform-row { margin-bottom: 1.25rem !important; }
  .mauticform-button-wrapper { margin-top: 0.5rem !important; }
  .mauticform-button {
    background: #0aa8a7 !important; /* primary button color */
    color: white !important;
    border: none !important;
    padding: 0.75rem 1.75rem !important;
    border-radius: 9999px !important; /* Pill style */
    font-size: 0.95rem !important;
    font-weight: 600 !important;
    cursor: pointer !important;
    transition: all 0.2s ease !important;
    font-family: inherit !important;
    box-shadow: 0 4px 6px -1px rgba(10, 168, 167, 0.2), 0 2px 4px -1px rgba(10, 168, 167, 0.1) !important;
  }
  .mauticform-button:hover { 
    opacity: 0.95 !important;
    transform: translateY(-1px) !important;
    box-shadow: 0 10px 15px -3px rgba(10, 168, 167, 0.3), 0 4px 6px -4px rgba(10, 168, 167, 0.3) !important;
  }
  .mauticform-message { 
    color: #0aa8a7 !important; 
    font-weight: 600 !important; 
    margin-bottom: 1rem !important; 
    border-radius: 0.75rem !important;
  }
  .mauticform-message:empty {
    display: none !important;
  }
  .mauticform-message:not(:empty) {
    padding: 1rem !important;
    background: #edf6f5 !important;
  }
  .mauticform-error,
  .mauticform-errormsg { 
    color: #dc2626 !important; 
    font-size: 0.85rem !important; 
    margin-top: 0.35rem !important; 
  }
</style>
